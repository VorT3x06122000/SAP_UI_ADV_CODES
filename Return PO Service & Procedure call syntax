    /**
     * UPDATE handler for UploadFiles media endpoint.
     * Handles PUT to /UploadFiles(<ID>)/content:
     *  - Accepts stream/buffer, persists to /tmp
     *  - Parses Excel via ExcelJS stream reader in batches
     *  - Upserts detail records and updates UploadFiles status
     *  - Cleans up temp file
     *
     * Notes:
     *  - Helpers expected: pipe, sleep, isBlankRow, updateExcelDetailsFromStream, sendReqSBPA
     *  - Modules expected: fs, fs/promises (fsp), ExcelJS, cds
     *
     * @param {import('@sap/cds/apis/services').Request} req - CAP request context
     * @param {Function} next - Next handler in pipeline
     * @returns {Promise<any>}
     */
    this.on("UPDATE", UploadFiles, async (req, next) => {
        // Guard: require uploadID; otherwise delegate
        if (!req.data.uploadID) return next();

        const url = req._.req.path;
        // Guard: only handle media update on /content endpoint
        if (!url.includes("content")) return next();

        const sUploadID = req.data.uploadID;
        const mediaObj = await SELECT.one.from(UploadFiles).where({ uploadID: sUploadID });

        if (!mediaObj) {
            req.reject(404, FILE_NOT_FND_FR_UPLDID);
            return;
        }

        const oContent = req.data.content; // may be a Readable stream or a Buffer depending on CAP & client
        //stream or a Buffer depending on CAP & client
        const uploadPath = `/tmp/${Date.now()}-file.xlsx`;

        cds.spawn({ user: req.user }, async () => {
            try {
                // 1) Persist the upload to disk safely
                if (oContent && typeof oContent.pipe === "function") {
                    // Readable stream (IncomingMessage or similar)
                    await pipe(oContent, fs.createWriteStream(uploadPath));
                } else if (Buffer.isBuffer(oContent)) {
                    // Buffer already in memory
                    await fsp.writeFile(uploadPath, oContent);
                } else if (req?._?.req && typeof req._.req.pipe === "function") {
                    // Fallback: pipe the raw HTTP request if content isn't provided as stream/buffer
                    await pipe(req._.req, fs.createWriteStream(uploadPath));
                } else {
                    throw new Error(NO_READABLE_CNTNT);
                }

                // 2) Process with ExcelJS stream reader
                const workbookReader = new ExcelJS.stream.xlsx.WorkbookReader(uploadPath);
                let bFirst = true;
                const iBatchSize = 1000;
                let aReqEntries = [];
                let headers = []; // ❗ you used `headers` without declaring it

                for await (const worksheet of workbookReader) {
                    if (!bFirst) break; // only first sheet
                    bFirst = false;

                    for await (const row of worksheet) {
                        if (row.number === 1) {
                            headers = row.values.map(v => (typeof v === "string" ? v.trim() : v));
                            continue;
                        } else if (row.number === 2) {
                            continue;
                        } else if (row.number === 3) {
                            continue;
                        }

                        if (isBlankRow(row.values, headers)) continue;

                        const record = {};
                        headers.forEach((header, index) => {
                            if (header) record[header] = row.values[index] ?? null;
                        });

                        aReqEntries.push(record);

                        if (aReqEntries.length === iBatchSize) {
                            // ❗ If this is async, await it to avoid races
                            await updateExcelDetailsFromStream(aReqEntries, sUploadID, req?.user?.id);
                            aReqEntries = [];
                        }

                        await sleep(20);
                    }
                }

                if (aReqEntries.length) {
                    await updateExcelDetailsFromStream(aReqEntries, sUploadID, req?.user?.id);
                }
                await sleep(20);

                // 3) Housekeeping and status calc
                await UPDATE(UploadFiles).where({ uploadID: sUploadID }).set({ content: null });

                // Document Type Similar Check
                let oUplRecds = await SELECT.from(RETPORecords).where({
                    uploadID: sUploadID
                });

                let oGroupedByPO = Object.groupBy(oUplRecds, (item) => {
                    return item.groupingPo;
                });

                Object.entries(oGroupedByPO).map(async (key, value) => {
                    let aGrpLineItems = key[1];

                    // Document Type Similar Check
                    let bDTSame = true, sDocType = aGrpLineItems[0].documentType;
                    for (let i = 1; i < aGrpLineItems.length; i++) {
                        if (aGrpLineItems[i].documentType !== sDocType) {
                            bDTSame = false;
                            break;
                        }
                    }

                    if (!bDTSame) {
                        await UPDATE(RETPORecords)
                            .where({
                                groupingPo: key[
                                    let aGrpLineItems = key[1];

                                // Document Type Similar Check
                                let bDTSame = true, sDocType = aGrpLineItems[0].documentType;
                                for(let i = 1; i<aGrpLineItems.length; i++) {
                            if (aGrpLineItems[i].documentType !== sDocType) {
                                bDTSame = false;
                                break;
                            }
                        }

                        if (!bDTSame) {
                            await UPDATE(RETPORecords)
                                .where({ groupingPo: key[0], uploadID: sUploadID })
                                .set({
                                    errorMessage: `Document type mismatch for PO creation request`,
                                    validationStatus: ERROR,
                                });
                            return;
                        }
                    });

                const [{ count: totalCount }] = await SELECT.from(RETPORecords)
                    .columns("count(*) as count")
                    .where({ uploadID: sUploadID });

                if (!totalCount) {
                    await UPDATE(UploadFiles).where({ uploadID: sUploadID }).set({
                        status: VALIDATION_FAIL,
                        comments: EXCEL_MPTY,
                        content: null,
                        base64String: null
                    });

                    return { message: EXCEL_MPTY, uploadID: sUploadID };
                }

                const [{ count: errCount }] = await SELECT.from(RETPORecords)
                    .columns("count(*) as count")
                    .where({ uploadID: sUploadID, validationStatus: ERROR });

                const [{ count: okCount }] = await SELECT.from(RETPORecords)
                    .columns("count(*) as count")
                    .where({ uploadID: sUploadID, validationStatus: SUCCESS });

                let uploadStatus = VALIDATION_FAIL;
                let sComments = VALIDATION_FAIL_FEW_REC;

                if (!errCount && okCount) {
                    uploadStatus = VALIDATION_SUCC_SENT_FOR_APPROV;
                    sComments = `Validation success for ${okCount} lines and awaiting for approval.`;

                    // Optionally await if this is async
                    const sUser = req?.user?.id;
                    const sUserName = `${req?.user?.attr.givenName || ""} ${req?.user?.attr.familyName || ""}`.trim();
                    const oSBPARes = await sendReqSBPA(sUploadID, sUser, sUserName);
                    console.log(oSBPARes);
                }

                const uploadEntry = {
                    dateTime: new Date(),
                    status: uploadStatus,
                    noOfRecords: totalCount,
                    comments: sComments,
                    content: null,
                    base64String: null
                };

                await UPDATE(UploadFiles).where({ uploadID: sUploadID }).set(uploadEntry);

                return { message: EXCEL_PROCESSED, uploadID: sUploadID };
            } catch (err) {
                console.error(`Upload failed for Upload Id: ${sUploadID} with error - `, err);
            } finally {
                // 4) Cleanup
                try { await fsp.unlink(uploadPath); } catch (e) { /* ignore */ }
            }
        });
        // Continue with next handler in the pipeline
        return next();
    });

    /**
