function sleep(ms) {

    return new Promise((resolve) => setTimeout(resolve, ms));

}

/**

* Determines whether a parsed Excel row should be considered blank,

* based on the provided headers to align indexes.

*

* A row is blank if for every header index the corresponding value is:

*   - undefined, null, or an empty/whitespace-only string.

*

* @param {Array<any>} rowValues - Row values array (e.g., from ExcelJS row.values).

* @param {Array<string>} headers - Header array used to align indices.

* @returns {boolean} True if the row is blank; otherwise false.

*/

function isBlankRow(rowValues, headers) {

    return headers.every((_, index) => {

        const value = rowValues[index];

        return value === undefined || value === null || (typeof value === "string" && value.trim() === "");

    });

}
















