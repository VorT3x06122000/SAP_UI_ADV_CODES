*

* @param {Array<Object>} aGrpLineItems - Line items belonging to the same batch/group (array for "C"; first element used for header fields).

* @param {"C"|"D"}       sAction       - Action code: "C" (create) or "D" (delete).

* @returns {Object} S/4 payload entry matching the expected API contract.

*/

function genS4PayloadEntry(aGrpLineItems, sAction) {

    let oPayloadEntry;

    if (sAction === "C") {

        // Extract common header fields from FIRST record

        const first = aGrpLineItems[0];

        oPayloadEntry = {

            PurchaseOrderType: first.documentType,

            CompanyCode: first.companyCode,

            PurchasingOrganization: first.purchaseOrg,

            PurchasingGroup: first.purchaseGroup,

            Supplier: first.vendor,

            POHeaderText: first.poheadertext || "",

            _PurchaseOrderItem: aGrpLineItems.map(rec => ({

                IsReturnsItem: true,

                Material: rec.material,

                Plant: rec.plant,

                OrderQuantity: rec.quantity,

                PurchaseOrderQuantityUnit: rec.PurchaseOrderQuantityUnit || "",

                StorageLocation: rec.storageLocation || "",

                PurchaseOrder: rec.purchaseDocument,

                PurchaseOrderItem: rec.purchaseDocumentItem,

                StockType: rec.stockType,

                PurchasingOrderReason: rec.reasonForOrdering,

                PurchaseContract: rec.agreementNo,

                PurchaseContractItem: rec.agreementItem,

                POItemText: rec.poitemtext,

                // Schedule lines: allow array or single batch

                _PurchaseOrderSch: [{ Batch: rec.batch }]

            }))

        };

    }

    return oPayloadEntry;

}

/**

