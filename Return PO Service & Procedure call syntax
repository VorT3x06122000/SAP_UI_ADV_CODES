                .where({
                    RicefwId: 'ZOSO_E_0007',
                    NameId: 'STATUS',
                    Active: '',
                    ConfigDeprecationCode: ''
                })

        );

        const db = cds.db;

        // Capture counts before deletion (for a simple delta summary
        let iPrevUploadTblRecords = await SELECT.from(UploadFiles).columns("count(uploadID) as iUploadCount");
        let iPrevDetailsTblRecords = await SELECT.from(RETPORecords).columns("count(ID) as iDetailsCount");

        try {
            // Raw SQL templates for deleting detail and header rows by createdAt + status
            let sQueryRETPOTbl = "DELETE FROM JNJ_OSOE0007_RETPORECORDS WHERE UPLOADID IN ( SELECT UPLOADID FROM JNJ_OSOE0007_UPLOADFILES WHERE CREATEDAT < ? AND STATUS = ? )"
            let sQueryUploadTbl = "DELETE FROM JNJ_OSOE0007_UPLOADFILES t WHERE t.UPLOADID IN ( SELECT UPLOADID FROM JNJ_OSOE0007_UPLOADFILES WHERE CREATEDAT < ? AND STATUS = ? )"

            // 7‑day deletion for all eligible statuses
            for (let each of aValidStatus) {
                await db.run(sQueryRETPOTbl, [fnGetTimeStamp(each.Value), each.Tag]);     // delete details first
                await db.run(sQueryUploadTbl, [fnGetTimeStamp(each.Value), each.Tag]);   // then headers
            }

            // Compute simple deltas for return message
            let iLaterUploadTblRecords = await SELECT.from(UploadFiles).columns("count(uploadID) as iUploadCount");
            let iLaterDetailsTblRecords = await SELECT.from(RETPORecords).columns("count(ID) as iDetailsCount");

            let iDeletedUplRecs = iPrevUploadTblRecords[0]?.iUploadCount - iLaterUploadTblRecords[0]?.iUploadCount;
            let iDeletedDetailsRecs = iPrevDetailsTblRecords[0]?.iDetailsCount - iLaterDetailsTblRecords[0]?.iDetailsCount;

            return "Respected Records are deleted - " + iDeletedUplRecs + " , " + iDeletedDetailsRecs;
        } catch (oError) {
            // Return a plain string on failure to match existing behavior
