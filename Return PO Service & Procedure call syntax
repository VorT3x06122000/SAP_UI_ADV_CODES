    /**
     * Handles SBPA approval callbacks for a given upload ID.
     * - Validates input/action and ensures the upload exists.
     * - On Reject (R): updates status and stores approver's comment.
     * - On Approve (A) at L1: marks status and triggers background upload tasks to S/4.
     *
     * @param {import('@sap/cds/apis/services').Request} req - CAP request context (expects data: { action:'A'|'R', level:'L1'|..., uploadId:string, comments?:string, timestamp?:string })
     * @returns {Promise<{message:string, uploadID:string}|void>} A short status payload or void when rejecting via `req.reject`.
     */
    this.on("SBPAapproval", async (req) => {
        let sAction = req.data.action;
        let sLevel = req.data.level;
        let sUploadId = req.data.uploadId;
        let sComments = req.data.comments;
        let sTimestamp = req.data.timestamp;    // Currently unused, kept for audit/tracking if needed

        // Ensure referenced UploadFiles entry exists
        let aFilePresent = await SELECT.from(UploadFiles).where({ uploadID: sUploadId });
        if (!aFilePresent.length) {
            return req.reject(400, ULPDID_NOT_PRSNT);
        }
        // Validate action code
        if (!["A", "R"].includes(sAction)) {
            return req.reject(500, ACTN_A_R);
        }

        if (sAction === "R") {
            // Rejection path: update status/comments and return
            await UPDATE(UploadFiles)
                .where({ uploadID: sUploadId })
                .set({ status: `Rejected by ${sLevel} Approver`, comments: sComments });
            return {
                message: UPDT_APRVR_ACTN_REJ,
                uploadID: sUploadId
            };
        }
        else {
            // Approval path
            if (sLevel === "L1") {
                // Mark as approved by L1; clear comments (as per current convention)
                await UPDATE(UploadFiles).where({ uploadID: sUploadId }).set({ status: L1_APPROVE, comments: "" });
                // Fetch all records for this upload
                let oUplRecds = await SELECT.from(RETPORecords).where({ uploadID: sUploadId });

                // Seggregating Create and Delete Records

                let aCrtRecs = [];
                oUplRecds.forEach(item => {
                    if (item.action === "C") {
                        aCrtRecs.push(item);
                    }

                });
                // Spawn background transaction to perform the S/4 upload tasks
                cds.spawn({ user: req.user }, async () => {
                    // The code here runs in a new transaction
                    await performUploadTasks(aCrtRecs, sUploadId);
                });

                return {
                    message: L1_APRVR_S4_TRIGG,
                    uploadID: sUploadId
                };
            }
        }
    });

    /**
     * Orchestrates post-approval upload tasks to S/4:
     * 1) Triggers S/4 upload for "Create" records.
     * 2) Triggers S/4 upload for "Delete" records.
     * 3) Evaluates errors and updates UploadFiles status/comments.
     * 4) Sends a success email on full success.
     *
     * @param {Array<Object>} aCrtRecs   - Records to create in S/4.
     * @param {Array<Object>} aDelRecs   - Records to delete in S/4.
     * @param {string}        sUploadId  - Upload ID to correlate status and detail records.
     * @returns {Promise<void>}
     */
    async function performUploadTasks(aCrtRecs, sUploadId) {
        // Trigger S/4 integration for create & delete flows
        await triggerS4UploadProcessForCreate(aCrtRecs, sUploadId);
        // Check if any detail records ended up with validation errors
        let aErrItems = await SELECT(RETPORecords).where({ uploadID: sUploadId, validationStatus: ERROR });

        if (aErrItems.length) // Not successful
        {
            await UPDATE(UploadFiles).where({ uploadID: sUploadId }).set({ status: ERR_S4, comments: SMTNG_WNT_WRNG_S4_UPLD });
        }
        else {
            // Successfull
            await UPDATE(UploadFiles).where({ uploadID: sUploadId }).set({ status: SUCC_S4, comments: DTA_UPLD_SUCC });
            // Notify stakeholders on success
            // sendMailForUploadSuccess("", sUploadId);
        }
    }

