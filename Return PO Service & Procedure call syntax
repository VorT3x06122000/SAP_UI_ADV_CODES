    /**
     * Maps human-friendly Excel column headers to internal field names and
     * returns a normalized data array with an `ok` flag and any unknown headers.
     *
     * - Accepts variations like "Document Type" and "DocumentType" (spaces collapsed).
     * - Normalizes header strings by trimming, collapsing spaces, and lowercasing.
     ** - Collects headers that don't match the known map into `unknownHeaders`.

     *

     * @param {Array<Object>} oExcelData - Rows parsed from Excel (array of objects keyed by header).

     * @returns {{ ok: boolean, data: Array<Object>, unknownHeaders: string[] }}

     *          An object with a success flag, converted rows, and a list of unmatched headers.

     */

    function mapConvertExcelColumns(oExcelData) {

        // Static mapping from Excel display headers to internal keys

        const rawMap = {

            "Action": "action",

            "Grouping PO": "groupingPo",

            "Grouping PO Item": "groupingPoItem",

            "Document Type": "documentType",

            "Vendor": "vendor",

            "Material": "material",

            "Plant": "plant",

            "Quantity": "quantity",

            "Delivery Date": "deliveryDate",

            "Storage Location": "storageLocation",

            "Batch": "batch",

            "Stock Type": "stockType",

            "Reason For Ordering": "reasonForOrdering",

            "Agreement No": "agreementNo",

            "Agreement Item": "agreementItem",

            "Reference PO": "purchaseDocument",

            "Reference PO Line Item": "purchaseDocumentItem",

            "PO Header Text": "poheadertext",

            "Purchase Organization": "purchaseOrg",

            "Purchase Group": "purchaseGroup",

            "Company Code": "companyCode",

            "PO Item Text": "poitemtext",

        };

        // Normalize function: trim, collapse spaces, remove spaces, lowercase for matching

        const norm = (s) => String(s).trim().replace(/\s+/g, " ").toLowerCase();

        const noSpaces = (s) => norm(s).replace(/\s/g, "");

        // Build a lookup that accepts BOTH "Document Type" and "DocumentType"

        const lookup = {};

        for (const [human, internal] of Object.entries(rawMap)) {

            lookup[norm(human)] = internal;       // "document type" -> "documentType"

            lookup[noSpaces(human)] = internal;   // "documenttype" -> "documentType"

        }

        const out = [];

        const unknownHeaders = new Set();

        // Convert each row by remapping its keys using the lookup

        for (const row of oExcelData) {

            const converted = {};

            for (const col of Object.keys(row)) {

                const key1 = norm(col);

                const key2 = noSpaces(col);

                const internal = lookup[key1] || lookup[key2];

                if (internal) {

                    converted[internal] = row[col];

                } else {

                    // Track headers that don't exist in the map for reporting

                    unknownHeaders.add(col);

                }

            }

            out.push(converted);

        }

        if (unknownHeaders.size) {

            // You can throw, return false, or include the info; here I include both.

            return { ok: false, data: out, unknownHeaders: Array.from(unknownHeaders) };

        }

        return { ok: true, data: out, unknownHeaders: [] };

    }

