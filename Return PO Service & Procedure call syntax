    /**
     * Before READ handler for RETPORecords.
     * Normalizes the `action` field from single-letter codes to readable labels.
     *
     * Hook: this.before('READ', RETPORecords, handler)
     * @param {import('@sap/cds/apis/services').Request} req - CAP request context.
     * @returns {Promise<void>} No return needed; modifies result rows in-place before READ.
     */
    this.before('READ', RETPORecords, async (req) => {
        // Load the target records (read-side transformation prior to delivery)
        const results = await SELECT.from(RETPORecords);

        results.forEach((record) => {
            if (record.action) {
                // Map one-letter action codes to descriptive labels
                switch (record.action.toUpperCase()) {
                    case "C":
                        record.action = CREATE;
                        break;
                    case "D":
                        record.action = DEELETE;
                        break;
                    default:
                        record.action = record.action; // leave as-is if unknown
                }
            }
        });

        // Note: no explicit return is required in a `before READ` hook;
        // CAP will use the mutated `results` for the response pipeline.
        // return results;
    });


    /**
     * Before CREATE handler for UploadFiles.
     * - Ensures a new upload gets default metadata (ID, status, comments, dateTime).
     * - Checks for duplicate file names and rejects the request if found.
     *
     * @param {import('@sap/cds/apis/services').Request} req - CAP request context for the CREATE operation.
     * @returns {Promise<void|string>} No return on success; returns a JSON string on early duplicate rejection.
     */
    this.before('CREATE', UploadFiles, async (req) => {
        var res = [];
        // Seed default fields for new uploads if not provided
        if (!req.data.uploadID) {
            req.data.uploadID = cds.utils.uuid();
            req.data.status = VALIDATION_PROGRESS;
            req.data.comments = WAIT_FOR_PROCESS;
            req.data.dateTime = new Date();
        }
        // Duplicate file-name check
        let sFileName = req.data.fileName;
        let aFilePresent = await SELECT.from(UploadFiles).where({ fileName: sFileName });

        if (aFilePresent.length > 0) {
            // Reject with meaningful message if the file name already exists
            req.reject(400, FILE_NAME_PRESENT);
            res = ({ "STATUS_CODE": 400, "MESSAGE": FILE_NAME_PRESENT });
            return JSON.stringify(res);
        }
    });


    /**
