    /**
     * Validates and persists Excel-derived records into RETPORecords.
     * - Maps incoming JSON columns to backend fields.
     * - Validates mandatory fields and normalizes dates.
     * - Flags each row as "Success" or "Error" with an aggregated error message.
     * - Inserts rows and triggers duplicate checks.
     * - Updates UploadFiles with a failure status if headers don't match.
     *
     * @param {Array<Object>} jsonData - Raw rows parsed from Excel (array of objects).
     * @param {string}        sUploadID - Upload ID to link each record.
     * @param {string}        sUser     - User ID used for spawning transactional updates.
     * @returns {Promise<{message:string, uploadID:string}|void>} Returns a message on header mismatch; otherwise void.
     */
    async function updateExcelDetailsFromStream(jsonData, sUploadID, sUser) {
        try {

            // Convert incoming Excel column headers/values into canonical structure
            oMappedJsonData = mapConvertExcelColumns(jsonData);
            // If mapping produced no data, mark upload as failed due to header mismatch
            if (!oMappedJsonData.data.length) {
                cds.spawn({ user: sUser }, async () => {
                    await UPDATE(UploadFiles).where({ uploadID: sUploadID }).set({
                        status: VALIDATION_FAIL,
                        comments: EXCEL_COL_MISMATCH,
                    });
                });

                return {
                    message: EXCEL_COL_MISMATCH,
                    uploadID: sUploadID,
                };
            }

            let aReqEnteries = [];
            // Mandatory fields and check variables
            var FIELD_LABELS;
            var aMandFields;
            // Validate & transform each record
            for (let item of oMappedJsonData.data) {
                var count = 0;
                let errors = [];
                if (!item.agreementNo || !item.agreementItem) {
                    // Mandatory fields expected per row if agreement number and agreement item is not there
                    FIELD_LABELS = { action: "Action", documentType: "Document Type", vendor: "Vendor", material: "Material", plant: "Plant", quantity: "Quantity", deliveryDate: "Delivery Date", storageLocation: "Storage Location", batch: "Batch", stockType: "Stock Type", reasonForOrdering: "Reason for Ordering", poheadertext: "PO Header Text", groupingPo: "Grouping PO", groupingPoItem: "Grouping PO Item" };
                    aMandFields = ["action", "documentType", "vendor", "material", "plant", "quantity", "deliveryDate", "storageLocation", "batch", "stockType", "reasonForOrdering", "poheadertext", "groupingPo", "groupingPoItem"];
                } else {
                    // Mandatory fields expected per row if agreement number and agreement item is there
                    FIELD_LABELS = { action: "Action", documentType: "Document Type", quantity: "Quantity", deliveryDate: "Delivery Date", storageLocation: "Storage Location", batch: "Batch", stockType: "Stock Type", reasonForOrdering: "Reason for Ordering", poheadertext: "PO Header Text", groupingPo: "Grouping PO", groupingPoItem: "Grouping PO Item" };
                    aMandFields = ["action", "documentType", "quantity", "deliveryDate", "storageLocation", "batch", "stockType", "reasonForOrdering", "poheadertext", "groupingPo", "groupingPoItem"];
                }
                // Check for presence of all mandatory fields and non-empty string value
                missingFields = [];
                try {
                    for (const field of aMandFields) {
                        const val = item[field];

                        // Empty means: null/undefined OR (string that trims to empty)
                        const isEmpty =
                            val === null ||
                            val === undefined ||
                            (typeof val === "string" && val.trim() === "");

                        if (isEmpty) {
                            missingFields.push(FIELD_LABELS[field] || field);
                        }
                    }

                    if (missingFields.length > 0) {
                        errors.push(MSNG_MAND_VAL + missingFields);
                    }

                    // Normalize date strings/numbers from Excel into backend-friendly format
                    if (item.deliveryDate) {
                        item.deliveryDate = normalizeExcelDate(item.deliveryDate);
                        if (!item.deliveryDate) {
                            errors.push(DT_FRMT_INVALID);
                        }
                    }
                    // Force action to uppercase and validate allowed values
                    if (item.action) {
                        item.action = item.action.toUpperCase();
                        if (!["C"].includes(item.action)) {
                            errors.push(ACTN_NOT_VALID);
                        }
                    }
                    if (item.stockType) {
                        item.stockType = item.stockType.toUpperCase();
                        if (!["U", "S", "X"].includes(item.stockType)) {
                            errors.push(STCKTYP_NOT_VALID);
                            count++;
                        }
                    }
                    if (item.documentType) {
                        item.documentType = item.documentType.toUpperCase();
                        if (!["NB2", "ZIR"].includes(item.documentType)) {
                            errors.push(DOCTYP_NOT_VALID);
                            count++;
                        }
                    }
                    if (item.storageLocation != null) {
                        const s = String(item.storageLocation).trim();
                        // Accept only exactly four digits: 0000 .. 9999
                        if (!/^\d{4}$/.test(s)) {
                            errors.push(STRGLOC_NOT_VALID);
                        }
                    }

                } catch (oErr) {
                    console.log("Date Normalization failed", oErr);
                }
                // Build final payload row with status & error details
                let lineStatusMsg = errors.length ? VALID_ERR : VALID_SUCC;
                if (count > 0) {
                    aReqEnteries.push({
                        ...item,
                        uploadID: sUploadID,
                        validationStatus: SUCCESS,
                        errorMessage: errors.length ? errors.join("; ") : lineStatusMsg,
                    });
                } else {

                    aReqEnteries.push({
                        ...item,
                        uploadID: sUploadID,
                        validationStatus: errors.length ? ERROR : SUCCESS,
                        errorMessage: errors.length ? errors.join("; ") : lineStatusMsg,
                    });
                }
            }
            // Insert records and perform duplicate detection/flagging in a spawned tx
            cds.spawn({ user: sUser }, async () => {
                // aReqEnteries = fncheckDataTypes(aReqEnteries);
                await INSERT.into(RETPORecords).entries(aReqEnteries);
                await addErrorForDuplicatesDB();
            });
        } catch (err) {
            console.error(`Upload failed for Upload Id - ${sUploadID} with error - `, err);
        }
    }

    /**
     * Marks duplicate rows in STRPRRecords with an error message.
     * Uses a single SQL UPDATE to set `errorMessage = 'Duplicate Record'`
     * for records that share the same (MATERIAL, PLANT, UPLOADID) combination.
     *
     * @returns {Promise<any>} Number of affected rows (driver-dependent result).
     */
    async function addErrorForDuplicatesDB() {
        // const tx = cds.transaction(req);
        const db = cds.db;

        const rawSqlQuery = `
        UPDATE JNJ_OSOE0007_RETPORECORDS t
