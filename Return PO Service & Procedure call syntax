/**

* Produces a deep-cloned payload with all `null` values removed.

* Uses a JSON stringify/parse cycle with a custom replacer to omit keys whose value is `null`.

*

* @param {Object} oPayload - The original payload object (may contain `null` values).

* @returns {Object} A new object identical to `oPayload` but without any `null` fields.

*/

function fnCleanPayload(oPayload) {

    const cleanJsonString = JSON.stringify(oPayload, (key, value) => {

        // If the value is null, return undefined to omit the key/value pair

        if (value === null) {

            return undefined;

        }

        return value;

    });

    return JSON.parse(cleanJsonString);

}

/**

* Normalizes various Excel/typical date inputs to an ISO (UTC) date string `YYYY-MM-DD`.

* Supports:

*  - JS Date instances (converted to UTC and formatted).

*  - Excel serial numbers (1900 and 1904 date systems; handles serial 60 bug).

*  - Common string formats: "YYYY-MM-DD", "MM/DD/YYYY", "DD-MM-YYYY",

*    and a generic fallback via Date parsing (normalized to UTC).

*

* @param {Date|number|string|null|undefined} val - The input value to normalize.

* @param {Object} [opts] - Optional configuration.

* @param {boolean} [opts.use1904=false] - Whether to interpret numbers using the Excel 1904 date system.

* @param {'truncate'|'round'} [opts.fraction='truncate'] - How to handle fractional day components in serials.

* @returns {string|null} ISO date string in the form `YYYY-MM-DD`, or `null` if unrecognized/empty.

*/

function normalizeExcelDate(val) {

    if (!val) return null;

    if (typeof val === "number") {

        let excelEpoch = new Date(Date.UTC(1899, 11, 30));

        excelEpoch.setUTCDate(excelEpoch.getUTCDate() + val);

        return excelEpoch.toISOString().slice(0, 10); // yyyy-mm-dd

    }

    if (typeof val === "string") {

        const mdyRegex = /^(\d{1,2})\/(\d{1,2})\/(\d{4})$/;

        const match = val.match(mdyRegex);

        if (match) {

            const [_, month, day, year] = match;

            return `${year}-${month.padStart(2, "0")}-${day.padStart(2, "0")}`;

        }

        if (/^\d{4}-\d{2}-\d{2}$/.test(val)) return val;

    }

    return null;

}


/**

* Splits an array into evenly sized chunks.

*

* @param {Array<any>} array - The source array to chunk.

* @param {number} chunkSize - The maximum size of each chunk (must be > 0).

* @returns {Array<Array<any>>} A new array of chunk arrays.

*/

function fnChunkArray(array, chunkSize) {

    const chunkedArr = [];

    for (let i = 0; i < array.length; i += chunkSize) {

        // Push a slice from i to i+chunkSize into the result

        chunkedArr.push(array.slice(i, i + chunkSize));

    }

    return chunkedArr;

}


/**

* Flattens an array of results collected per chunk into a single array.

* Assumes each entry in `chunks` is itself an array (e.g., from Promise.allSettled).

*

* @param {Array<Array<any>>} chunks - Array of chunked result arrays.

* @returns {Array<any>} A single-level array containing all results in order.

*/

function processAllChunksSerially(chunks) {

    let combinedResults = [];

    for (const chunk of chunks) {

        // Append the entire chunk to the accumulator

        combinedResults.push(...chunk);

    }

    return combinedResults;

}

/**

* Returns a Promise that resolves after a given number of milliseconds.

*

* @param {number} ms - Milliseconds to wait.

* @returns {Promise<void>} Resolves after the delay.

