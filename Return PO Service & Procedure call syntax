    async function deleteRecords(req) {
        const SwitchFrameworkSrv = await cds.connect.to('ZSB_SWITCH_FRAMEWORK');
        const { SwitchTable } = SwitchFrameworkSrv.entities;

        const aValidStatus = await SwitchFrameworkSrv.run(
